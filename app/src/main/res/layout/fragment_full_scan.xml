<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Pattern Scan"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MA · MACD · RSI · Bollinger · Ribbon · Candlestick"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Timeframe selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIMEFRAME"
            android:textColor="@color/text_label"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:id="@+id/fs_timeframe_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/fs_btn_15m"
                style="@style/TimeframeButton"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                android:text="15M" android:backgroundTint="@color/bg_card" />
            <Button android:id="@+id/fs_btn_1h"
                style="@style/TimeframeButtonSelected"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                android:text="1H" android:textColor="@color/accent_gold"
                android:backgroundTint="@color/bg_card" />
            <Button android:id="@+id/fs_btn_4h"
                style="@style/TimeframeButton"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                android:text="4H" android:backgroundTint="@color/bg_card" />
            <Button android:id="@+id/fs_btn_1d"
                style="@style/TimeframeButton"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                android:text="1D" android:backgroundTint="@color/bg_card" />
            <Button android:id="@+id/fs_btn_1w"
                style="@style/TimeframeButton"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1"
                android:text="1W" android:backgroundTint="@color/bg_card" />
        </LinearLayout>
    </LinearLayout>

    <!-- MA Periods row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_input_field">
            <EditText
                android:id="@+id/fs_et_fast"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="12dp"
                android:hint="Fast MA (50)"
                android:text="50"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_label"
                android:textSize="14sp"
                android:inputType="number"
                android:background="@null"
                android:gravity="center_vertical" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field">
            <EditText
                android:id="@+id/fs_et_slow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="12dp"
                android:hint="Slow MA (200)"
                android:text="200"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_label"
                android:textSize="14sp"
                android:inputType="number"
                android:background="@null"
                android:gravity="center_vertical" />
        </FrameLayout>
    </LinearLayout>

    <!-- Progress bar (hidden when idle) -->
    <LinearLayout
        android:id="@+id/ll_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_progress_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scanning…"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_progress_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/accent_gold"
                android:textSize="12sp" />
        </LinearLayout>

        <android.widget.ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressTint="@color/accent_gold"
            android:progressBackgroundTint="@color/border_color"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <!-- Stats bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_fs_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RESULTS (0)"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_fs_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Results list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_full_scan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:paddingBottom="72dp" />

    <!-- Scan button (floating style at bottom) -->
    <Button
        android:id="@+id/btn_full_scan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"
        android:text="🔍  SCAN ALL PAIRS"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/bg_primary"
        android:backgroundTint="@color/accent_gold"
        android:stateListAnimator="@null"
        app:cornerRadius="28dp" />

</LinearLayout>
