<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="14dp"
    android:paddingHorizontal="4dp">

    <!-- Row 1: Coin name + Score badge + Prediction -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Coin Name (color = signal strength) -->
        <TextView
            android:id="@+id/tv_coin_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BTC/USDT"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Score badge -->
        <TextView
            android:id="@+id/tv_score"
            android:layout_width="48dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="+87"
            android:background="@drawable/bg_score_badge"
            android:layout_marginEnd="8dp" />

        <!-- Prediction label -->
        <TextView
            android:id="@+id/tv_prediction_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Strong Buy"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Row 2: Price change + Predicted % + Volume -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp">

        <TextView
            android:id="@+id/tv_price_change"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="24h: +3.21%"
            android:textSize="12sp"
            android:textColor="#8A8FA8" />

        <TextView
            android:id="@+id/tv_predicted_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target: +2.5%"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_signal_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 signals"
            android:textSize="11sp"
            android:textColor="#8A8FA8" />
    </LinearLayout>

    <!-- Row 3: Signal chips (scrollable) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/ll_signal_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Row 4: Candlestick patterns (if any) -->
    <TextView
        android:id="@+id/tv_candle_patterns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:textSize="11sp"
        android:textColor="#8A8FA8"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2D3A"
        android:layout_marginTop="12dp" />
</LinearLayout>
